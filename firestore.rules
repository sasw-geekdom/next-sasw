rules_version = '2';

// All Firestore access in this app goes through the Firebase Admin SDK on the
// server (route handlers + server components), which BYPASSES these rules.
// The browser never reads or writes Firestore directly, so we deny all client
// access as defense in depth. If a future feature needs direct client reads
// (e.g. a public list rendered client-side), open that specific path only.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
